# Supabase project credentials (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Analytics 4 measurement ID (optional — analytics are skipped when empty)
VITE_GA_ID=

# EmailJS (emailjs.com) — sends Contact form enquiries by email (optional;
# skipped when empty, the lead still saves to Supabase either way)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
